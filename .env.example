########################################
# Core API keys
########################################

OPENAI_API_KEY="your-openai-key-here"
OPENAI_MODEL="gpt-4.1"

TAVILY_API_KEY="your-tavily-key-here"
TAVILY_ENABLED=true
TAVILY_MAX_COST_USD=1.00


########################################
# Global paths & memory
########################################

MEMORY_FILE="logs/sessions/default_memory.json"
WORKER_MEMORY_FILE="logs/sessions/worker_memory.json"

# Where summaries, checkpoints, discovery logs go
LOG_DIR="logs"
SESSION_DIR="logs/sessions"


########################################
# High-level worker defaults
########################################

WORKER_GOAL_DEFAULT="Long run autonomous research on reparodynamics, RYE, TGRM, and stability science."
WORKER_DOMAIN_DEFAULT="general"
RUNTIME_MINUTES_DEFAULT=60


########################################
# Single worker overrides
########################################

WORKER_GOAL="Test long run Reparodynamics session on stability and RYE."
WORKER_DOMAIN="general"
WORKER_MAX_MINUTES=60
WORKER_STOP_RYE=
WORKER_RUNTIME_PROFILE="8_hours"
WORKER_ROLE="agent"
WORKER_RESUME=true
WORKER_WATCHDOG_MINUTES=5.0
WORKER_FOREVER=false


########################################
# Swarm
########################################

WORKER_SWARM_ROLES="researcher,critic,planner"
WORKER_SWARM=false
WORKER_MODE="single"

WORKER_SHIFT_MINUTES=
WORKER_REPEAT_SHIFTS=false


########################################
# Meta controller (Option C)
########################################

WORKER_META=true
WORKER_META_MAX_SEGMENTS=6


########################################
# Source controls
########################################

WORKER_SOURCES="web,pubmed,semantic,pdf"
WORKER_WEB=true
WORKER_PUBMED=true
WORKER_SEMANTIC=true
WORKER_PDF=true
WORKER_BIOMARKERS=false
WORKER_SANDBOX=false


########################################
# Run identity
########################################

WORKER_RUN_ID="local-test-run"
WORKER_TAVILY_KEY="your-tavily-key-here"


########################################
# Streamlit UI
########################################

STREAMLIT_SERVER_PORT=8501
APP_BASE_URL=""
UI_DEFAULT_DOMAIN="general"
UI_DEFAULT_RUNTIME_PRESET="1 Hour Run"


########################################
# Logging & diagnostics
########################################

LOG_LEVEL="INFO"
RYE_VERBOSE_LOGGING=true


########################################
# Safety / dev switches
########################################

SANDBOX_FS_MODE=false
OFFLINE_MODE=false


########################################
# LEARNING ENGINE (MAXED)
########################################
# These directly enhance the CoreAgent + MemoryStore + presets

# Turn learning on/off
LEARNING_ENABLED=true

# Minimum cycles needed before training
LEARNING_MIN_EXAMPLES=4

# How strongly new learning events override old memory
LEARNING_WEIGHT_RECENT=0.70
LEARNING_WEIGHT_PRIOR=0.30

# Update learning parameters each N cycles
LEARNING_UPDATE_INTERVAL=6

# Decay factor for old learning entries
LEARNING_DECAY=0.92

# Max notes stored before auto-compression
LEARNING_MEMORY_LIMIT=20000

# Enable auto-labeling of discovered structures (math + longevity)
LEARNING_AUTO_TAGGING=true

# Enable cross-cycle discovery refinement
LEARNING_CYCLE_LINKING=true

# Enable domain-specific pattern extraction
LEARNING_DOMAIN_AWARE=true

# Learning-report export toggle
LEARNING_EXPORT_REPORTS=true


########################################
# DISCOVERY ENGINE (MAXED)
########################################

DISCOVERY_MIN_COMBINED_SCORE=0.55
DISCOVERY_MIN_NOVELTY_SCORE=0.45
DISCOVERY_MIN_SUPPORT_SCORE=0.45
DISCOVERY_MAX_PER_CYCLE=5

DISCOVERY_ENABLE_Z_SCORES=true
DISCOVERY_ENABLE_DOMAIN_TAGS=true
DISCOVERY_ENABLE_BIOMARKER_CLASSIFIER=true
DISCOVERY_ENABLE_MATH_CLASSIFIER=true
DISCOVERY_FINGERPRINT_HISTORY_LIMIT=5000


########################################
# MEMORY MANAGEMENT (MAXED)
########################################

# Auto-compact memory every N cycles
MEMORY_AUTO_COMPACT_INTERVAL=150

# SQLite WAL configuration for large runs
MEMORY_SQLITE_WAL=true

# Enable backup snapshots
MEMORY_SNAPSHOT_INTERVAL_MINUTES=30

# Shallow compaction vs deep (0,1,2)
MEMORY_COMPACTION_LEVEL=2

# Enable batch writes for 90-day runs
MEMORY_BATCH_WRITES=true
MEMORY_BATCH_SIZE=50

# Migration behavior
MEMORY_MIGRATION_ENABLED=true


########################################
# SWARM INTELLIGENCE (MAXED)
########################################

# Swarm learning
SWARM_SHARED_MEMORY=true
SWARM_SHARED_DISCOVERY=true

# Enable critic→researcher feedback boosting
SWARM_FEEDBACK_BOOST=true

# Enable swarm mode LLM diversity
SWARM_MODEL_VARIATION=true

# Enable role-specialized reward shaping
SWARM_ROLE_OPTIMIZATION=true
