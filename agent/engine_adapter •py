# agent/engine_adapter.py

"""
Engine adapter for the Autonomous Research Agent.

Goal
-----
This module is the "nice middle layer" between:

    - Streamlit UI (or any front end)
    - File based job queue (agent.run_jobs)
    - Background worker (agent.engine_worker / agent.engine_worker_queue)

It gives you:

    1) A structured EngineJobRequest dataclass so the UI can describe
       single, swarm, or meta runs in a clean way.

    2) Helper functions to:
        - Build a job config in the exact format engine_worker expects
        - Submit jobs to the file based queue (runs/pending)
        - Inspect job status across queued, active, finished, error
        - Load result JSON and progress JSON for a given run_id

    3) Optional convenience helpers for "quick" single and swarm jobs
       so the UI does not have to know all details.

Job flow
--------
UI code should do something like:

    from agent.engine_adapter import EngineJobRequest, submit_job, get_job_overview

    req = EngineJobRequest(
        goal="Finite 32 agent longevity swarm test",
        domain="longevity",
        mode="swarm",
        roles=["longevity_researcher"] * 32,
        max_rounds=2,
        runtime_profile="1_hour",
    )

    run_id = submit_job(req, meta={"created_by": "streamlit_ui"})

The background worker (engine_worker_queue or engine_worker in queue mode)
will then pick up the job, run it, and write:

    - runs/finished/{run_id}.json          -> final result
    - runs/active/{run_id}_progress.json   -> optional progress
    - runs/error/{run_id}_error.txt        -> on failure

This adapter is intentionally "maxed out" for your use:

    - Strong typing hints
    - Clean dataclass for job requests
    - Status and result helpers tailored for the Streamlit dashboard
    - No hard dependency on the UI layer
"""

from __future__ import annotations

import json
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any, Dict, List, Literal, Optional, Tuple

from .run_jobs import (
    RunJob,
    create_job,
    list_jobs,
    load_job_by_id,
    progress_path,
    result_path,
    error_log_path,
    BASE_DIR,
    PENDING_DIR,
    ACTIVE_DIR,
    FINISHED_DIR,
    ERROR_DIR,
)


EngineMode = Literal["single", "swarm", "meta"]


@dataclass
class EngineJobRequest:
    """
    High level description of a research run.

    Fields map cleanly onto the engine_worker queue configuration.

    Core fields
    -----------
    goal          : natural language goal for the run
    domain        : "longevity", "math", "general", etc
    mode          : "single", "swarm", or "meta"

    Single agent
    ------------
    role          : label for the core agent role (default "agent")
    max_cycles    : finite cycle bound for single agent runs

    Swarm
    -----
    roles         : list of role names for swarm agents
    max_rounds    : finite round bound for swarm runs

    Time and control
    ----------------
    max_minutes       : optional wall time guard (minutes)
    stop_rye          : optional RYE threshold for early stop
    runtime_profile   : optional preset label ("1_hour", "8_hours", etc)
    resume            : resume from checkpoint if available
    watchdog_minutes  : how often the worker does safe checkpoint and health checks

    Sources and extras
    ------------------
    source_controls   : optional dict of booleans for web, pdf, pubmed, etc
    extra             : free form dict for any additional engine specific config
    """

    goal: str
    domain: str = "general"
    mode: EngineMode = "single"

    # Single agent
    role: str = "agent"
    max_cycles: Optional[int] = None

    # Swarm
    roles: Optional[List[str]] = None
    max_rounds: Optional[int] = None

    # Time and stopping
    max_minutes: Optional[float] = None
    stop_rye: Optional[float] = None
    runtime_profile: Optional[str] = None
    resume: bool = True
    watchdog_minutes: float = 5.0

    # Sources and advanced config
    source_controls: Optional[Dict[str, bool]] = None
    extra: Dict[str, Any] = field(default_factory=dict)

    def to_job_config(self) -> Dict[str, Any]:
        """
        Build a job config dict in the exact shape expected by engine_worker.

        It uses the same key names as _process_single_job in engine_worker:

            mode, goal, domain, role, roles, max_cycles, max_rounds,
            max_minutes, stop_rye, runtime_profile, resume,
            watchdog_minutes, source_controls

        plus any keys from extra.
        """
        cfg: Dict[str, Any] = {
            "mode": self.mode,
            "goal": self.goal,
            "domain": self.domain,
            "role": self.role,
            "resume": self.resume,
            "watchdog_minutes": self.watchdog_minutes,
        }

        if self.roles is not None:
            cfg["roles"] = list(self.roles)

        if self.max_cycles is not None:
            cfg["max_cycles"] = int(self.max_cycles)

        if self.max_rounds is not None:
            cfg["max_rounds"] = int(self.max_rounds)

        if self.max_minutes is not None:
            cfg["max_minutes"] = float(self.max_minutes)

        if self.stop_rye is not None:
            cfg["stop_rye"] = float(self.stop_rye)

        if self.runtime_profile is not None:
            cfg["runtime_profile"] = str(self.runtime_profile)

        if self.source_controls is not None:
            cfg["source_controls"] = {str(k): bool(v) for k, v in self.source_controls.items()}

        # Merge any extra keys last so advanced callers can override or extend
        if self.extra:
            for k, v in self.extra.items():
                cfg[str(k)] = v

        return cfg


