def submit_job(
    request: EngineJobRequest,
    meta: Optional[Dict[str, Any]] = None,
    run_id: Optional[str] = None,
) -> str:
    """
    Create and enqueue a new job using the file based queue.

    Returns:
        run_id string of the created job.

    Example
    -------
        req = EngineJobRequest(
            goal="Finite 32 agent longevity test",
            domain="longevity",
            mode="swarm",
            roles=["longevity_researcher"] * 32,
            max_rounds=2,
            runtime_profile="1_hour",
        )
        run_id = submit_job(req, meta={"created_by": "streamlit_ui"})
    """
    config = request.to_job_config()
    run_id = create_job(config=config, meta=meta, run_id=run_id)
    return run_id


def queue_single_run(
    goal: str,
    domain: str = "general",
    role: str = "agent",
    max_cycles: int = 10,
    max_minutes: Optional[float] = None,
    stop_rye: Optional[float] = None,
    runtime_profile: Optional[str] = None,
    source_controls: Optional[Dict[str, bool]] = None,
    meta: Optional[Dict[str, Any]] = None,
) -> str:
    """
    Convenience wrapper for a finite single agent run.

    Useful for quick tests from the UI without building EngineJobRequest manually.
    """
    req = EngineJobRequest(
        goal=goal,
        domain=domain,
        mode="single",
        role=role,
        max_cycles=max_cycles,
        max_minutes=max_minutes,
        stop_rye=stop_rye,
        runtime_profile=runtime_profile,
        source_controls=source_controls,
    )
    return submit_job(req, meta=meta)


def queue_swarm_run(
    goal: str,
    domain: str = "general",
    roles: Optional[List[str]] = None,
    swarm_size: Optional[int] = None,
    max_rounds: int = 1,
    max_minutes: Optional[float] = None,
    stop_rye: Optional[float] = None,
    runtime_profile: Optional[str] = None,
    source_controls: Optional[Dict[str, bool]] = None,
    meta: Optional[Dict[str, Any]] = None,
) -> str:
    """
    Convenience wrapper for a finite swarm run.

    If swarm_size is given and roles is None, a uniform role list of that
    length is created using the name "agent".

    Example
    -------
        # 32 agent longevity swarm, 2 rounds
        run_id = queue_swarm_run(
            goal="Finite 32 agent longevity test",
            domain="longevity",
            swarm_size=32,
            max_rounds=2,
            runtime_profile="1_hour",
            meta={"label": "32x longevity test"},
        )
    """
    if roles is None and swarm_size is not None:
        roles = ["agent"] * swarm_size

    req = EngineJobRequest(
        goal=goal,
        domain=domain,
        mode="swarm",
        roles=roles,
        max_rounds=max_rounds,
        max_minutes=max_minutes,
        stop_rye=stop_rye,
        runtime_profile=runtime_profile,
        source_controls=source_controls,
    )
    return submit_job(req, meta=meta)


