def get_job_status(run_id: str) -> Dict[str, Any]:
    """
    Return a compact status dict for a given run_id.

    Fields:
        run_id
        status           -> queued, active, finished, error, or unknown
        created_at       -> unix time (if known)
        updated_at       -> unix time (if known)
        has_progress     -> bool (progress JSON present)
        has_result       -> bool (result JSON present)
        error_log_path   -> string path if error log exists
        meta             -> job.meta if available
    """
    job = load_job_by_id(run_id)
    progress = progress_path(run_id)
    result = result_path(run_id)
    error_txt = error_log_path(run_id)

    status = "unknown"
    created_at = None
    updated_at = None
    meta: Optional[Dict[str, Any]] = None

    if isinstance(job, RunJob):
        status = job.status
        created_at = job.created_at
        updated_at = job.updated_at
        meta = job.meta

    info: Dict[str, Any] = {
        "run_id": run_id,
        "status": status,
        "created_at": created_at,
        "updated_at": updated_at,
        "has_progress": progress.exists(),
        "has_result": result.exists(),
        "error_log_path": str(error_txt) if error_txt.exists() else None,
        "meta": meta,
    }
    return info


def get_job_overview(
    status: Optional[str] = None,
    limit: int = 50,
) -> List[Dict[str, Any]]:
    """
    List recent jobs with basic information for UI tables.

    status:
        None       -> all jobs across queued, active, finished, error
        "queued"   -> pending jobs
        "active"   -> running jobs
        "finished" -> completed jobs
        "error"    -> failed jobs
    """
    jobs = list_jobs(status=status, limit=limit)
    overview: List[Dict[str, Any]] = []

    for job in jobs:
        run_id = job.run_id
        progress = progress_path(run_id)
        result = result_path(run_id)
        error_txt = error_log_path(run_id)

        overview.append(
            {
                "run_id": run_id,
                "status": job.status,
                "created_at": job.created_at,
                "updated_at": job.updated_at,
                "domain": job.config.get("domain"),
                "mode": job.config.get("mode") or job.config.get("engine_mode") or "single",
                "goal": job.config.get("goal"),
                "has_progress": progress.exists(),
                "has_result": result.exists(),
                "has_error_log": error_txt.exists(),
                "meta": job.meta,
            }
        )

    return overview


def load_result_json(run_id: str) -> Optional[Dict[str, Any]]:
    """
    Load the finished result JSON for a job, if it exists.

    Returns:
        dict or None
    """
    path = result_path(run_id)
    if not path.exists():
        return None
    try:
        with path.open("r", encoding="utf8") as f:
            return json.load(f)
    except Exception:
        return None


def load_progress_json(run_id: str) -> Optional[Dict[str, Any]]:
    """
    Load live progress JSON for a job, if it exists.

    The worker is expected to write something like:

        {
            "run_id": "...",
            "status": "active",
            "current_cycle": 12,
            "total_cycles": 90,
            "last_update_utc": "...",
            "notes": "optional"
        }
    """
    path = progress_path(run_id)
    if not path.exists():
        return None
    try:
        with path.open("r", encoding="utf8") as f:
            return json.load(f)
    except Exception:
        return None


def load_error_text(run_id: str) -> Optional[str]:
    """
    Load error log text for a job if the worker wrote one.
    """
    path = error_log_path(run_id)
    if not path.exists():
        return None
    try:
        return path.read_text(encoding="utf8")
    except Exception:
        return None


# ---------------------------------------------------------------------------
# Paths and layout helpers (nice for debugging in Streamlit)
# ---------------------------------------------------------------------------


def describe_queue_layout() -> Dict[str, str]:
    """
    Return a simple mapping of the key run folders for debugging.

    This is handy to show in the Streamlit UI when users wonder
    where jobs and results live on disk.
    """
    return {
        "base_dir": str(Path(BASE_DIR).resolve()),
        "pending_dir": str(Path(PENDING_DIR).resolve()),
        "active_dir": str(Path(ACTIVE_DIR).resolve()),
        "finished_dir": str(Path(FINISHED_DIR).resolve()),
        "error_dir": str(Path(ERROR_DIR).resolve()),
    }
